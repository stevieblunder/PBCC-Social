# --- BUDGET STACK (Vercel + Supabase + Forward Email) ---

# Supabase (PostgreSQL + Auth)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=secret-service-role-key

# Email (Forward Email SMTP)
SMTP_HOST=smtp.forwardemail.net
SMTP_PORT=465
SMTP_USER=hello@yourdomain.com
SMTP_PASS=your-forward-email-smtp-password
EMAIL_FROM=hello@yourdomain.com
EMAIL_FROM_NAME=Putney Bridge CC

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Gemini API
GEMINI_API_KEY=
